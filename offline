<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DeTech | Scheduled Maintenance</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;500;700&family=Inter:wght@300;400;500;600;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        display: ['Space Grotesk', 'sans-serif'],
                        body: ['Inter', 'sans-serif'],
                    },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                        'float-delayed': 'float 6s ease-in-out 3s infinite',
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0px)' },
                            '50%': { transform: 'translateY(-20px)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #030308;
            font-family: 'Inter', sans-serif;
        }
        /* Full screen structural background picture overlay matching your asset vault */
        .maintenance-bg {
            background: linear-gradient(135deg, rgba(3, 3, 8, 0.88), rgba(10, 2, 0, 0.92)), url('images/DETECH.JPG');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }
        .hero-gradient {
            background: linear-gradient(135deg, #ffffff 0%, #d4d4d8 40%, #ef4444 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .btn-spinner {
            display: inline-block;
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: #ffffff;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            flex-shrink: 0;
        }
        .btn-spinner.dark {
            border-color: rgba(0, 0, 0, 0.2);
            border-top-color: #111827;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #030308; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
        input:-webkit-autofill,
        input:-webkit-autofill:hover,
        input:-webkit-autofill:focus {
            -webkit-text-fill-color: #e4e4e7;
            -webkit-box-shadow: 0 0 0px 1000px #18181b inset;
        }
    </style>
</head>
<body class="maintenance-bg text-white min-h-screen flex flex-col justify-center items-center px-6 relative overflow-hidden">

    <div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-red-600/5 rounded-full blur-[150px] animate-pulse-slow"></div>
        <div class="absolute top-1/3 left-1/4 w-[400px] h-[400px] bg-orange-600/3 rounded-full blur-[100px] animate-float"></div>
        <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.15) 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>

    <div class="absolute top-20 left-10 w-2 h-2 bg-red-500/20 rounded-full animate-float hidden md:block"></div>
    <div class="absolute top-40 right-20 w-3 h-3 bg-orange-500/10 rounded-full animate-float-delayed hidden md:block"></div>

    <main class="relative z-10 text-center max-w-xl mx-auto space-y-8 backdrop-blur-md bg-black/40 p-8 md:p-12 rounded-3xl border border-white/5 shadow-2xl">

        <div class="inline-flex items-center gap-2 bg-red-600/20 border border-red-500/30 text-red-400 px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest">
            <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
            System Optimization
        </div>

        <div class="space-y-4">
            <h1 class="font-display text-4xl md:text-6xl font-bold tracking-tight leading-none hero-gradient">
                Platform<br>Maintenance
            </h1>
            <p class="text-gray-400 text-sm md:text-base max-w-md mx-auto leading-relaxed">
                Thank you for your submission. Our systems are temporarily offline as we secure infrastructure parameters and run deployment validations.
            </p>
        </div>

        <div class="bg-black/40 border border-white/5 p-6 rounded-2xl max-w-md mx-auto space-y-4 shadow-inner">
            <h2 class="text-gray-300 font-medium text-sm tracking-wide">Enter email to receive live network launch alerts</h2>

            <form id="subscribe-form" novalidate class="space-y-3">
                <div>
                    <input
                        id="sub-email"
                        type="email"
                        placeholder="Enter your email address"
                        class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 outline-none transition-all duration-300 focus:border-red-500/50"
                        required
                        autocomplete="email"
                    >
                    <p id="sub-error"   class="text-left text-xs text-red-400 mt-2 hidden"></p>
                    <p id="sub-success" class="text-center text-xs text-green-400 font-medium mt-2 hidden"></p>
                </div>

                <button
                    type="submit"
                    id="btn-sub-submit"
                    class="w-full bg-white text-gray-950 font-bold text-xs uppercase tracking-wider py-3 px-6 rounded-xl hover:bg-red-500 hover:text-white transition-all duration-300 flex items-center justify-center gap-2"
                >
                    <span id="btn-sub-text">Notify Me</span>
                    <div id="btn-sub-spinner" class="btn-spinner dark hidden"></div>
                </button>
            </form>
        </div>

        <div class="pt-2">
            <button
                onclick="goBack()"
                class="inline-flex items-center gap-2 text-gray-400 hover:text-white text-xs uppercase tracking-widest font-semibold transition-colors duration-300"
            >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Return Home
            </button>
        </div>
    </main>

    <footer class="absolute bottom-8 text-center z-10">
        <p class="text-[10px] text-gray-600 uppercase tracking-[0.25em] font-medium">
            &copy; 2026 DeTech Technology Core
        </p>
    </footer>

    <script type="module">
        import { initializeApp }                          from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
        import { getFirestore, collection, addDoc,
                 query, where, getDocs }                  from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

        const firebaseConfig = {
            apiKey:            "AIzaSyAM8SIm4DIi800D-Apa2SgfPpHVh-hrjUc",
            authDomain:        "website-791e9.firebaseapp.com",
            projectId:         "website-791e9",
            storageBucket:     "website-791e9.firebasestorage.app",
            messagingSenderId: "35656723392",
            appId:             "1:35656723392:web:dd4447685537af9a32f625"
        };

        const app = initializeApp(firebaseConfig);
        const db  = getFirestore(app);

        const emailInput  = document.getElementById('sub-email');
        const subError    = document.getElementById('sub-error');
        const subSuccess  = document.getElementById('sub-success');
        const btnSubmit   = document.getElementById('btn-sub-submit');
        const btnText     = document.getElementById('btn-sub-text');
        const btnSpinner  = document.getElementById('btn-sub-spinner');

        function resetUI() {
            btnSubmit.disabled    = false;
            btnText.textContent   = 'Notify Me';
            btnSpinner.classList.add('hidden');
            emailInput.style.borderColor = '';
        }

        function setLoading() {
            btnSubmit.disabled  = true;
            btnText.textContent = 'Subscribing...';
            btnSpinner.classList.remove('hidden');
        }

        function showError(msg) {
            subError.textContent = msg;
            subError.classList.remove('hidden');
            subSuccess.classList.add('hidden');
            emailInput.style.borderColor = '#ef4444';
            resetUI();
        }

        function showSuccess(msg) {
            subSuccess.textContent = msg;
            subSuccess.classList.remove('hidden');
            subError.classList.add('hidden');
            emailInput.style.borderColor = '#22c55e';
            btnSpinner.classList.add('hidden');
            btnText.textContent = 'Subscribed ã';
        }

        function withTimeout(promise, ms = 10000) {
            const timeout = new Promise((_, reject) =>
                setTimeout(() => reject(new Error('TIMEOUT')), ms)
            );
            return Promise.race([promise, timeout]);
        }

        document.getElementById('subscribe-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            subError.classList.add('hidden');
            subSuccess.classList.add('hidden');
            emailInput.style.borderColor = '';

            const email = emailInput.value.trim();

            if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                showError('Please enter a valid email address.');
                return;
            }

            setLoading();

            try {
                const q        = query(collection(db, 'subscribers'), where('email', '==', email));
                const snapshot = await withTimeout(getDocs(q));

                if (!snapshot.empty) {
                    showSuccess("You're already on the list! Redirecting you home... Þ");
                    emailInput.value = '';
                    setTimeout(() => { window.location.href = getHomeUrl(); }, 2500);
                    return;
                }

                await withTimeout(addDoc(collection(db, 'subscribers'), {
                    email,
                    subscribedAt: new Date().toISOString(),
                    featurePage: 'maintenance-shutdown'
                }));

                showSuccess('You\'re on the list! Taking you home... ÞË');
                emailInput.value = '';
                setTimeout(() => { window.location.href = getHomeUrl(); }, 2500);

            } catch (err) {
                console.error('Subscribe error:', err);
                if (err.message === 'TIMEOUT') {
                    showError('Request timed out. Please check your connection and try again.');
                } else if (err.code === 'permission-denied') {
                    showError('Submission blocked. Please contact support at admin@detechnologies.co.za');
                } else {
                    showError('Something went wrong. Please try again in a moment.');
                }
            }
        });

        function getHomeUrl() {
            return window.location.origin + '/';
        }

        window.goBack = function () {
            if (!document.referrer || window.history.length <= 1) {
                window.location.href = getHomeUrl();
            } else {
                window.history.back();
            }
        };

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') window.goBack();
        });

        document.addEventListener('mousemove', (e) => {
            const x = (e.clientX / window.innerWidth  - 0.5) * 15;
            const y = (e.clientY / window.innerHeight - 0.5) * 15;
            document.querySelectorAll('.animate-float').forEach((el) => {
                el.style.transform = `translate(${x}px, ${y}px)`;
            });
        });
    </script>
</body>
</html>
